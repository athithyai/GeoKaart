# ─────────────────────────────────────────────────────────────────────────────
# CijfersChat — Environment Variables
# Copy this file to .env (project root, NOT inside backend/)
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: Groq (cloud, fast inference — get key at https://console.groq.com) ──
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=openai/gpt-oss-20b   # or llama-3.3-70b-versatile, llama-3.1-8b-instant
# LLM_API_KEY=gsk_...your_groq_key...

# ── LLM: Ollama (default — free, local, no API key needed) ───────────────────
# 1. Install Ollama: https://ollama.com/download
# 2. Start it:       ollama serve
# 3. Pull a model:   ollama pull llama3.2
#                    (alternatives: phi4, mistral, gemma2, qwen2.5)
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
LLM_API_KEY=ollama

# ── LLM: OpenAI GPT-4o (optional — better accuracy, needs API key) ───────────
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-...your_openai_key...

# ── LLM: Groq (optional — fast cloud inference, needs API key) ───────────────
# Uncomment and replace the Ollama lines above with these:
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...your_groq_key...

# ── Data APIs (public Dutch open data — no key required) ─────────────────────
CBS_ODATA_BASE=https://opendata.cbs.nl/ODataFeed/odata
PDOK_OGC_BASE=https://api.pdok.nl/cbs/gebiedsindelingen/ogc/v1

# ── Cache TTLs (seconds) ─────────────────────────────────────────────────────
CACHE_TTL_METADATA=3600
CACHE_TTL_GEOMETRY=86400
CACHE_TTL_DATA=900
